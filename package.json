{
  "name": "carf",
  "private": true,
  "version": "2.0.0-alpha",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "bridge:dev": "cargo run --manifest-path src-tauri/Cargo.toml --bin carf-bridge",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "compile:agent": "frida-compile src-agent/src/index.ts -o src-agent/dist/_agent.js -c -T none",
    "compile:agent:watch": "frida-compile src-agent/src/index.ts -o src-agent/dist/_agent.js -w -T none",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.7",
    "@solid-primitives/keyboard": "^1.2.8",
    "@solid-primitives/storage": "^4.3.1",
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@tauri-apps/plugin-fs": "^2.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "corvu": "^0.6.0",
    "lucide-solid": "^0.577.0",
    "solid-js": "^1.9.4",
    "solid-motionone": "^1.0.3",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.2.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/frida-gum": "^19.0.2",
    "frida-java-bridge": "^7.0.12",
    "frida-objc-bridge": "^8.0.5",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^3.0.0"
  }
}
